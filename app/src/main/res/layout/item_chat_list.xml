<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:padding="16dp"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/chat_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/baseline_send_24"
            app:tint="#2E6A5E" />

        <View
            android:id="@+id/dot_unread_item"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_alignTop="@id/chat_icon"
            android:layout_alignEnd="@id/chat_icon"
            android:background="@drawable/search_bg"
            android:backgroundTint="#FF5252"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/chat_icon"
            android:layout_toStartOf="@id/btn_delete_chat"
            android:layout_marginStart="16dp"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/chat_request_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Request #12345"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/chat_last_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to continue chat"
                android:textSize="14sp"
                android:textColor="#666666" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_delete_chat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#FF5252" />
    </RelativeLayout>
</androidx.cardview.widget.CardView>