<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create Community"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A2A4E"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/et_comm_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Community Name"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/et_comm_icon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Icon URL (Optional)"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btn_save_community"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Community"
        android:backgroundTint="#008CFF"
        android:textColor="@android:color/white"/>

</LinearLayout>
