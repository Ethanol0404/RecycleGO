<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/search_bg">

    <TextView
        android:id="@+id/detail_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Request Details"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A2A4E"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/detail_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/detail_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/detail_center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/detail_remarks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/detail_address"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

    <ImageView
        android:id="@+id/detail_image"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginBottom="16dp"
        android:scaleType="centerCrop"
        android:src="@drawable/request"
        android:visibility="gone" />

    <TextView
        android:id="@+id/detail_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:background="@drawable/search_bg"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp"/>

    <GridLayout
        android:id="@+id/layout_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:useDefaultMargins="true"
        android:alignmentMode="alignMargins"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action_message"
            style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="Chat"
            android:textAllCaps="false"
            android:textColor="#2E7D32"
            app:icon="@drawable/baseline_send_24"
            app:iconTint="#2E7D32"
            app:strokeWidth="1dp"
            app:strokeColor="#2E7D32"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action_edit"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="Edit"
            android:textAllCaps="false"
            android:textColor="#1976D2"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconTint="#1976D2"
            app:strokeWidth="1dp"
            app:strokeColor="#1976D2"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action_accept"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_columnSpan="2"
            android:text="Accept Request"
            android:textAllCaps="false"
            android:backgroundTint="#2E6A5E"
            app:cornerRadius="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1B4D43"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action_confirm_pickup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_columnSpan="2"
            android:text="Confirm Pickup"
            android:textAllCaps="false"
            android:backgroundTint="#2E6A5E"
            app:cornerRadius="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1B4D43"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action_confirm_complete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_columnSpan="2"
            android:text="Verify &amp; Earn Points"
            android:textAllCaps="false"
            android:backgroundTint="#FBC02D"
            android:textColor="#000000"
            app:cornerRadius="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="#F9A825"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action_delete"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="Delete"
            android:textAllCaps="false"
            android:textColor="#D32F2F"
            app:strokeWidth="1dp"
            app:strokeColor="#D32F2F"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action_report"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:text="Report"
            android:textAllCaps="false"
            android:textColor="#757575"
            app:strokeWidth="1dp"
            app:strokeColor="#757575"
            android:visibility="gone"/>
    </GridLayout>

</LinearLayout>
